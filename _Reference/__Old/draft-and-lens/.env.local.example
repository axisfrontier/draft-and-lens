# Anthropic — server-side only; never exposed to the client bundle
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Clerk — authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase — Postgres with row-level security
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — subscriptions and billing (Stage 7)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Upstash Redis — rate limiting (Stage 3+)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Optional — dev/staff instrumentation gate (DLTrace, §20)
DL_TRACE_ENABLED=false

# Optional — analyst adaptive-thinking effort tuning (prototype default: medium)
DL_ANALYST_EFFORT=medium
